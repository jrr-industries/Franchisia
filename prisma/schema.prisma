generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  franchisor
  franchisee
  consultant
  investor
  supplier
}

enum AccountStatus {
  pending_email_verification
  pending_phone_verification
  pending_profile_completion
  pending_admin_review
  verified
  rejected
  need_more_information
}

enum ListingStatus {
  active
  pending
  suspended
  inactive
}

enum ApplicationStatus {
  submitted
  reviewing
  accepted
  rejected
  withdrawn
}

enum MessageType {
  text
  image
  file
  system
}

enum NotificationType {
  new_lead
  application_received
  application_status_changed
  meeting_reminder
  new_message
  new_review
  connection_request
  system_alert
}

model User {
  id                 String          @id @default(uuid()) @db.Uuid
  email              String          @unique
  emailVerified      DateTime?       @map("email_verified") @db.Timestamptz
  passwordHash       String          @map("password_hash")
  role               UserRole        @default(franchisee)
  accountStatus      AccountStatus   @default(pending_email_verification) @map("account_status")

  fullName           String          @map("full_name")
  avatarUrl          String?         @map("avatar_url")
  headline           String?
  bio                String?
  phone              String?
  phoneVerified      DateTime?       @map("phone_verified") @db.Timestamptz
  location           String?

  investmentCapacity Decimal?        @map("investment_capacity") @db.Decimal(12, 2)
  industries         String[]
  experienceYears    Int?            @map("experience_years")
  website            String?
  linkedinUrl        String?         @map("linkedin_url")

  companyName             String?  @map("company_name")
  businessEmail           String?  @map("business_email")
  businessRegistrationNumber String? @map("business_registration_number")
  businessRegistrationDoc String?  @map("business_registration_doc")
  companyLogo             String?  @map("company_logo")
  gstNumber               String?  @map("gst_number")
  consultancyName         String?  @map("consultancy_name")
  preferredIndustry       String?  @map("preferred_industry")
  preferredLocation       String?  @map("preferred_location")
  investmentRange         String?  @map("investment_range")
  resumeUrl               String?  @map("resume_url")

  submittedForReviewAt DateTime?  @map("submitted_for_review_at") @db.Timestamptz
  reviewedBy           String?    @map("reviewed_by") @db.Uuid
  reviewedAt           DateTime?  @map("reviewed_at") @db.Timestamptz
  verificationNotes    String?    @map("verification_notes")
  rejectionReason      String?    @map("rejection_reason")

  isActive           Boolean         @default(true) @map("is_active")
  lastLoginAt        DateTime?       @map("last_login_at") @db.Timestamptz
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  skills             UserSkill[]
  interests          UserInterest[]
  education          UserEducation[]
  experience         UserExperience[]

  companies          Company[]
  listings           FranchiseListing[]
  applications       Application[]
  sentConnections    Connection[]        @relation("followed_by")
  receivedConnections Connection[]       @relation("following_user")
  companyFollowers   CompanyFollower[]
  messages           Message[]
  participants       ConversationParticipant[]
  notifications      Notification[]
  reviews            Review[]
  organizedMeetings  Meeting[]
  meetingParticipants MeetingParticipant[]
  auditLogs          AuditLog[]
  sessions           Session[]
  verificationTokens VerificationToken[]
  documents          UserDocument[]

  @@index([email])
  @@index([role])
  @@index([accountStatus])
  @@map("users")
}

model UserSkill {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @map("user_id") @db.Uuid
  skill   String

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@map("user_skills")
}

model UserInterest {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  interest String

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, interest])
  @@map("user_interests")
}

model UserEducation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  school    String
  degree    String?
  field     String?
  startYear Int?     @map("start_year")
  endYear   Int?     @map("end_year")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_education")
}

model UserExperience {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  company     String
  role        String
  description String?
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  isCurrent   Boolean   @default(false) @map("is_current")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_experience")
}

model Company {
  id            String        @id @default(uuid()) @db.Uuid
  ownerId       String        @map("owner_id") @db.Uuid
  name          String
  slug          String        @unique
  logoUrl       String?       @map("logo_url")
  bannerUrl     String?       @map("banner_url")
  industry      String
  description   String?
  website       String?
  foundedYear   Int?          @map("founded_year")
  employeeCount String?       @map("employee_count")
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  isVerified    Boolean       @default(false) @map("is_verified")
  status        ListingStatus @default(pending)
  followerCount Int           @default(0) @map("follower_count")
  listingCount  Int           @default(0) @map("listing_count")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  listings      FranchiseListing[]
  followers     CompanyFollower[]
  reviews       Review[]

  @@index([slug])
  @@index([industry])
  @@index([status])
  @@map("companies")
}

model FranchiseListing {
  id                String         @id @default(uuid()) @db.Uuid
  companyId         String         @map("company_id") @db.Uuid
  createdBy         String         @map("created_by") @db.Uuid

  title             String
  slug              String         @unique
  description       String?
  industry          String
  businessType      String?        @map("business_type")

  investmentMin     Decimal?       @map("investment_min") @db.Decimal(12, 2)
  investmentMax     Decimal?       @map("investment_max") @db.Decimal(12, 2)
  roiPercentage     Decimal?       @map("roi_percentage") @db.Decimal(5, 2)
  franchiseFee      Decimal?       @map("franchise_fee") @db.Decimal(12, 2)
  royaltyFee        String?        @map("royalty_fee")
  breakEvenMonths   Int?           @map("break_even_months")

  location          String?
  city              String?
  country           String?
  isRemote          Boolean        @default(false) @map("is_remote")

  images            String[]
  videoUrl          String?        @map("video_url")

  status            ListingStatus  @default(pending)
  isFeatured        Boolean        @default(false) @map("is_featured")

  viewCount         Int            @default(0) @map("view_count")
  applicationCount  Int            @default(0) @map("application_count")

  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  publishedAt       DateTime?      @map("published_at") @db.Timestamptz

  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser     User           @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  applications      Application[]
  reviews           Review[]

  @@index([companyId])
  @@index([industry])
  @@index([status])
  @@index([investmentMin, investmentMax])
  @@map("franchise_listings")
}

model Application {
  id                  String            @id @default(uuid()) @db.Uuid
  listingId           String            @map("listing_id") @db.Uuid
  applicantId         String            @map("applicant_id") @db.Uuid
  status              ApplicationStatus @default(submitted)

  coverMessage        String?           @map("cover_message")
  investmentCapacity  Decimal?          @map("investment_capacity") @db.Decimal(12, 2)

  internalNotes       String?           @map("internal_notes")

  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  listing             FranchiseListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant           User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([listingId, applicantId])
  @@index([listingId])
  @@index([applicantId])
  @@map("applications")
}

model Connection {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower    User     @relation("followed_by", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following_user", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("connections")
}

model CompanyFollower {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("company_followers")
}

model Conversation {
  id        String                     @id @default(uuid()) @db.Uuid
  subject   String?
  createdAt DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime                   @default(now()) @map("updated_at") @db.Timestamptz

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @map("conversation_id") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  lastReadAt      DateTime?    @map("last_read_at") @db.Timestamptz

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @map("conversation_id") @db.Uuid
  senderId        String       @map("sender_id") @db.Uuid
  content         String
  messageType     MessageType  @default(text) @map("message_type")
  attachmentUrl   String?      @map("attachment_url")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String?
  data      Json?            @db.JsonB
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  companyId  String?  @map("company_id") @db.Uuid
  listingId  String?  @map("listing_id") @db.Uuid
  rating     Int
  title      String?
  content    String?
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  reviewer   User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  listing    FranchiseListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([listingId])
  @@map("reviews")
}

model Meeting {
  id            String               @id @default(uuid()) @db.Uuid
  organizerId   String               @map("organizer_id") @db.Uuid
  title         String
  description   String?
  meetingUrl    String?              @map("meeting_url")
  startTime     DateTime             @map("start_time") @db.Timestamptz
  endTime       DateTime?            @map("end_time") @db.Timestamptz
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz

  organizer     User                 @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  participants  MeetingParticipant[]
}

model MeetingParticipant {
  id        String   @id @default(uuid()) @db.Uuid
  meetingId String   @map("meeting_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    String   @default("pending")

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model SiteStat {
  id    String @id @default(uuid()) @db.Uuid
  value String
  label String
  sort  Int    @default(0)

  @@map("site_stats")
}

model SiteContact {
  id      String @id @default(uuid()) @db.Uuid
  email   String
  phone   String
  address String

  @@map("site_contact")
}

model AboutPage {
  id      String @id @default(uuid()) @db.Uuid
  section String @unique
  content String

  @@map("about_page")
}

model AboutTeam {
  id   String @id @default(uuid()) @db.Uuid
  name String
  role String
  bio  String?
  sort Int    @default(0)

  @@map("about_team")
}

model AboutTimeline {
  id    String @id @default(uuid()) @db.Uuid
  year  String
  title String
  desc  String?
  sort  Int    @default(0)

  @@map("about_timeline")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  tableName String?  @map("table_name")
  recordId  String?  @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data") @db.JsonB
  newData   Json?    @map("new_data") @db.JsonB
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // "email" or "phone"
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("verification_tokens")
}

model UserDocument {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // "business_registration", "company_logo", "resume", etc.
  url       String
  fileName  String   @map("file_name")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_documents")
}
